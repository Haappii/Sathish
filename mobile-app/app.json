{
  "expo": {
    "name": "Haappii Billing",
    "slug": "haappii-billing-mobile",
    "version": "2.7.0",
    "icon": "./assets/app_icon.png",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/app_icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#050810"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.haappii.billing"
    },
    "android": {
      "package": "com.haappii.billing",
      "versionCode": 12,
      "adaptiveIcon": {
        "foregroundImage": "./assets/app_icon.png",
        "backgroundColor": "#050810"
      },
      "permissions": [
        "INTERNET",
        "ACCESS_NETWORK_STATE",
        "BLUETOOTH",
        "BLUETOOTH_ADMIN",
        "BLUETOOTH_CONNECT",
        "BLUETOOTH_SCAN",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "./plugins/withBluetoothPrinter"
    ],
    "owner": "srikar52",
    "extra": {
      "eas": {
        "projectId": "9c4dae84-9eec-4f50-95da-0c9afdd9b292"
      }
    }
  }
}
