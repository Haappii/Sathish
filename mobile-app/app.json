{
  "expo": {
    "name": "Haappii Billing",
    "slug": "haappii-billing-mobile",
    "version": "2.2.0",
    "icon": "./assets/app_logo.png",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/app_logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#1d4ed8"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.haappii.billing"
    },
    "android": {
      "package": "com.haappii.billing",
      "versionCode": 3,
      "adaptiveIcon": {
        "foregroundImage": "./assets/app_logo.png",
        "backgroundColor": "#1d4ed8"
      },
      "permissions": [
        "INTERNET",
        "ACCESS_NETWORK_STATE"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "owner": "haappii52",
    "extra": {
      "eas": {
        "projectId": "c8982018-797c-4547-be07-e8ef42475df6"
      }
    }
  }
}
