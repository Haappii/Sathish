{
  "expo": {
    "name": "Haappii Billing",
    "slug": "haappii-billing-mobile",
    "version": "2.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#1d4ed8"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.haappii.billing"
    },
    "android": {
      "package": "com.haappii.billing",
      "versionCode": 2,
      "adaptiveIcon": {
        "backgroundColor": "#1d4ed8"
      },
      "permissions": [
        "INTERNET",
        "ACCESS_NETWORK_STATE"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "extra": {
      "eas": {
        "projectId": "haappii-billing-mobile"
      }
    }
  }
}
