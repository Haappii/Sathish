# Global application config
# Legacy fallback example.
# Preferred shared config file: `config.example.txt`

# App mode
APP_ENV=development

# Backend
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/shop_billing
JWT_SECRET=change-this-before-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5180,http://127.0.0.1:5173,http://127.0.0.1:5180

# Local runner / deploy hosts and ports
PUBLIC_HOST=localhost
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_HOST=0.0.0.0
FRONTEND_PORT=5173
DESKTOP_FRONTEND_PORT=5180

# Frontend / API / links
VITE_API_BASE=/api
VITE_WINDOWS_APP_URL=/downloads/poss-desktop-setup.exe
VITE_ANDROID_APK_URL=/downloads/haappii-billing.apk
VITE_IOS_APP_URL=

# Desktop wrapper
APP_URL=http://localhost:5180
APP_URL_DEFAULT=http://localhost:5180

# Optional support email config
SUPPORT_EMAIL_ENABLED=false
SUPPORT_EMAIL=
SUPPORT_SENDER_EMAIL=
SUPPORT_SENDER_PASSWORD=
SUPPORT_SMTP_HOST=smtp.gmail.com
SUPPORT_SMTP_PORT=465

# Public invoice links / WhatsApp (Meta Cloud API)
PUBLIC_WEB_BASE_URL=http://localhost:5173
INVOICE_SHARE_SECRET=change-this-before-production
WHATSAPP_META_ACCESS_TOKEN=
WHATSAPP_META_PHONE_NUMBER_ID=
WHATSAPP_DEFAULT_COUNTRY_CODE=91
WHATSAPP_META_GRAPH_VERSION=v22.0
