[Unit]
Description=POSS Backend (FastAPI/Uvicorn)
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/POSS/backend
Environment=PYTHONUNBUFFERED=1
ExecStart=/home/ubuntu/POSS/backend/venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 8000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target

