# ================================
# Backend environment variables
# ================================

# Database
# Example (Postgres):
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/shop_billing
DATABASE_URL=

# JWT
JWT_SECRET=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Support email (optional)
# If disabled/missing, support endpoints can still store tickets in DB (if enabled).
SUPPORT_EMAIL_ENABLED=false
SUPPORT_EMAIL=
SUPPORT_SENDER_EMAIL=
SUPPORT_SENDER_PASSWORD=
SUPPORT_SMTP_HOST=smtp.gmail.com
SUPPORT_SMTP_PORT=465
